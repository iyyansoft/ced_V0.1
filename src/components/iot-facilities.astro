---
import sensors from "../data/sensors.json";
---

<h2>
    IoT Facilities
</h2>


<div class="search-container">
    <input 
        type="text" 
        id="searchInput"
        placeholder="Search for a sensor..." 
        class="search-input"
    />
</div>

<!-- Sensors List -->
<div id="sensorsContainer" class="sensors-container">
    {sensors.map((sensor) => (
        <div class="sensor-card" data-name={sensor.Components.toLowerCase()}>
            <h3>{sensor.Components}</h3>
            <p><strong>No:</strong> {sensor.No}</p>
            <p><strong>Specifications:</strong> {sensor.Specification}</p>
            <div class="image-container">
                <img 
                    src={sensor.Image_Path.replace("C:\\Astro-internship CED website\\nebulous-nova (2)\\nebulous-nova\\nebulous-nova\\public", "")} 
                    alt={sensor.Components} 
                    class="sensor-image"
                />
            </div>
        </div>
    ))}
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    const searchInput = document.getElementById("searchInput") as HTMLInputElement;

    if (!searchInput) return;

    const sensorCards = document.querySelectorAll(".sensor-card");

    searchInput.addEventListener("input", function () {
        let query = searchInput.value.toLowerCase().trim(); // ✅ No more TypeScript error

        sensorCards.forEach(card => {
            let name = card.getAttribute("data-name") || "";
            (card as HTMLElement).style.display = name.includes(query) ? "block" : "none";
        });
    });
});

    </script>
    

<style>

.search-container {
    text-align: center;
    margin: 20px auto;
}

.search-input {
    width: 50%;
    padding: 10px;
    font-size: 1rem;
    border: 1px solid #ddd;
    border-radius: 5px;
    outline: none;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
}

/* Sensors Grid */
.sensors-container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
}

/* Sensor Card */
.sensor-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #ddd;
    padding: 15px;
    width: 280px;
    text-align: center;
    background-color: #f9f9f9;
    border-radius: 8px;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
    min-height: 320px;
}

.sensor-card h3 {
    margin: 0;
    font-size: 1.2rem;
    color: #333;
}

.sensor-card p {
    margin: 5px 0;
    font-size: 0.9rem;
    color: #555;
}

/* Keeps images at the bottom */
.image-container {
    margin-top: auto;
    display: flex;
    justify-content: center;
    align-items: center;
}

.sensor-image {
    max-width: 100%;
    height: auto;
    margin-top: 10px;
    border-radius: 5px;
}

h2{
    text-align: center; 
    margin-top: 30px; 
    font-size: 2rem;
}
</style>
