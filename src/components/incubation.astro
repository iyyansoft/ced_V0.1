  text-align:center;
  margin-bottom:60px;
  animation:fadeDown 1s ease both;
}

.header-block h1{
  font-size:44px;
  font-weight:900;
  background:linear-gradient(90deg,#4f46e5,#ec4899);
  -webkit-background-clip:text;
  color:transparent;
}

.header-line{
  width:100px;
  height:5px;
  background:linear-gradient(90deg,#ec4899,#6366f1);
  margin:18px auto 0;
  border-radius:6px;
  animation:expandLine 1.2s ease;
}

/* ================= INTRO ================= */
.intro-box{
  background:#ffffff;
  padding:36px;
  border-radius:22px;
  box-shadow:0 25px 60px rgba(0,0,0,.1);
  max-width:900px;
  margin:0 auto 70px;
  position:relative;
  animation:fadeUp 1s ease both;
}

.intro-box::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:22px;
  background:linear-gradient(120deg,#6366f122,#ec489922);
  z-index:-1;
}

/* ================= SECTION TITLE ================= */
.section-title{
  margin:70px 0 35px;
  font-size:30px;
  font-weight:800;
  position:relative;
  animation:fadeLeft .9s ease both;
}

.section-title::after{
  content:"";
  display:block;
  width:60px;
  height:4px;
  margin-top:10px;
  background:#6366f1;
  border-radius:4px;
}

/* ================= FEATURE CARDS ================= */
.feature-card{
  background:#ffffff;
  padding:30px;
  border-radius:24px;
  height:100%;
  box-shadow:0 20px 45px rgba(0,0,0,.08);
  transition:all .45s cubic-bezier(.4,0,.2,1);
  position:relative;
  overflow:hidden;
}

.feature-card::before{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(120deg,#6366f1,#ec4899);
  opacity:0;
  transition:.4s;
}

.feature-card:hover::before{
  opacity:.08;
}

.feature-card:hover{
  transform:translateY(-12px) scale(1.02);
  box-shadow:0 35px 70px rgba(0,0,0,.15);
}

.feature-card h3{
  font-size:22px;        /* 👈 size kammi */
  line-height:1.3;
  margin-bottom:12px;
  color:#4f46e5;
  font-weight:700;
}

.feature-card ul{
  padding-left:20px;
}

.feature-card li{
  margin:12px 0;
  line-height:1.6;
  position:relative;
}

/* ================= TIMELINE ================= */
.timeline{
  position:relative;
  margin-top:50px;
  padding-left:40px;
}

.timeline::before{
  content:"";
  position:absolute;
  left:12px;
  top:0;
  bottom:0;
  width:4px;
  background:linear-gradient(180deg,#6366f1,#ec4899);
  border-radius:4px;
}

.timeline-item{
  position:relative;
  display:flex;
  gap:24px;
  margin-bottom:40px;
  animation:fadeRight 1s ease both;
}

.timeline-item:nth-child(2){animation-delay:.15s}
.timeline-item:nth-child(3){animation-delay:.3s}
.timeline-item:nth-child(4){animation-delay:.45s}

.timeline-item .dot{
  width:22px;
  height:22px;
  background:#ffffff;
  border:5px solid #6366f1;
  border-radius:50%;
  margin-top:4px;
  flex-shrink:0;
}

/* ================= CENTER HIGHLIGHT ================= */
.center-highlight{
  margin:80px auto 40px;
  text-align:center;
  font-size:22px;
  font-weight:800;
  color:#ec4899;
  animation:pulse 2.5s infinite;
}

/* ================= FINAL NOTE ================= */
.final-note{
  background:#ffffff;
  padding:30px;
  border-left:7px solid #6366f1;
  border-radius:20px;
  box-shadow:0 18px 40px rgba(0,0,0,.1);
  animation:fadeUp 1s ease both;
}

/* ================= ANIMATIONS ================= */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(40px)}
  to{opacity:1;transform:none}
}

@keyframes fadeDown{
  from{opacity:0;transform:translateY(-40px)}
  to{opacity:1;transform:none}
}

@keyframes fadeLeft{
  from{opacity:0;transform:translateX(-40px)}
  to{opacity:1;transform:none}
}

@keyframes fadeRight{
  from{opacity:0;transform:translateX(40px)}
  to{opacity:1;transform:none}
}

@keyframes expandLine{
  from{width:0}
  to{width:100px}
}

@keyframes pulse{
  0%,100%{transform:scale(1)}
  50%{transform:scale(1.05)}
}

/* ================= MOBILE ================= */
@media(max-width:768px){
  .header-block h1{font-size:32px}
  .section-title{font-size:24px}
}



.ced-cta-btn{
  display:block;              /* block element */
  width:fit-content;          /* content width mattum */
  margin:70px auto 0;         /* 👈 center horizontally */

  padding:12px 28px;
  font-size:22px;
  font-weight:700;

  color:#fff;
  background:linear-gradient(135deg,#6366f1,#ec4899);
  border-radius:40px;
  text-decoration:none;       /* 👈 anchor underline remove */

  cursor:pointer;
  position:relative;
  overflow:hidden;

  box-shadow:0 14px 30px rgba(99,102,241,.35);
  transition:all .35s ease;
}

/* hover effect */
.ced-cta-btn:hover{
  transform:translateY(-4px) scale(1.05);
  box-shadow:0 32px 65px rgba(236,72,153,.55);
}

/* mobile */
@media(max-width:768px){
  .ced-cta-btn{
    width:90%;
    text-align:center;
  }
}





/* ================= GRANTS BOX ================= */
.grants-box{
  background:linear-gradient(135deg,#ffffff,#fdf2f8);
  padding:40px;
  border-radius:26px;
  max-width:900px;
  margin:40px auto 60px;
  text-align:center;

  box-shadow:0 25px 60px rgba(0,0,0,.1);
  position:relative;
}

.grants-box p{
  font-size:18px;
  color:#374151;
  margin-bottom:24px;
  line-height:1.7;
}

/* link button */
.grants-link{
  display:inline-block;
  padding:14px 34px;
  font-size:18px;
  font-weight:700;

  color:#fff;
  background:linear-gradient(135deg,#ec4899,#6366f1);
  border-radius:40px;
  text-decoration:none;

  box-shadow:0 16px 40px rgba(236,72,153,.35);
  transition:all .35s ease;
}

.grants-link:hover{
  transform:translateY(-4px) scale(1.05);
  box-shadow:0 30px 70px rgba(99,102,241,.45);
}







/* ================= ROOT ================= */
.ced-notable-all{
  padding:90px 0;
  background:linear-gradient(180deg,#fdf2f8,#f8fafc);
  font-family:system-ui;
  margin-top: 120px;
}

.ced-notable-title{
  text-align:center;
  font-size:34px;
  font-weight:900;
