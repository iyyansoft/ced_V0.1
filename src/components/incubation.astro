}

.ced-points li{
  margin:10px 0;
  line-height:1.6;
}

/* ================= GOODNESS MEDIA ================= */
.ced-goodness-media{
  display:flex;
  justify-content:center;   /* 👈 center horizontally */
  align-items:center;
  width:100%;
}

/* image + button */
.ced-media-box{
  display:flex;
  flex-direction:column;    /* 👈 image top, button bottom */
  align-items:center;       /* 👈 center both */
  gap:18px;
}

.ced-media-box img{
  width:280px;
  height:410px;
  object-fit:cover;
  border-radius:22px;
  box-shadow:0 18px 40px rgba(0,0,0,.18);
}

/* button */
.ced-video-btn{
  padding:14px 26px;
  border-radius:30px;
  background:linear-gradient(135deg,#ec4899,#6366f1);
  color:#fff;
  font-weight:700;
  text-decoration:none;
  box-shadow:0 14px 30px rgba(236,72,153,.45);
  transition:.3s;
  margin-top:20px;
}

.ced-video-btn:hover{
  transform:translateY(-4px) scale(1.05);
}



/* ================= MOBILE ================= */
@media(max-width:768px){
  .ced-image-row{
