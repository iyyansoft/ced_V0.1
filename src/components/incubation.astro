}








/* ================= SECTION ================= */
.ced-dpiit-section{
  padding:70px 0 0;
  background:#f8fafc;
  overflow:hidden;
  margin-top: 120px;  
}

/* ================= TEXT ================= */
.ced-dpiit-title{
  font-size:34px;
  font-weight:900;
  color:#111827;
  margin-bottom:20px;
}

.ced-dpiit-desc{
  font-size:17px;
  color:#374151;
