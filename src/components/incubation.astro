/* ================= MEINE IMAGES ================= */
.ced-image-row{
  display:flex;
  justify-content:center;  /* 👈 horizontal center */
}


.ced-image-row img{
  width:50%;
  height:360px;
  object-fit:cover;
  border-radius:20px;
  box-shadow:0 15px 35px rgba(0,0,0,.18);
}


/* ================= GOODNESS CONTENT ================= */
.ced-founder{
  font-size:16px;
  color:#374151;
  margin-bottom:18px;
}

.ced-points{
