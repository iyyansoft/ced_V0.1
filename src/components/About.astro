---
import { onMount } from 'solid-js';
import Typed from 'typed.js';

// For any JavaScript code you need, you can write it here.
// For instance, initializing the typed.js (if you're using it for text typing effect).
const TypedComponent = () => {
  let typedElement: HTMLSpanElement | null = null;

onMount(() => {
  const typed = new Typed('#typed', {
    stringsElement: '#typed-strings',
    typeSpeed: 50,
    backSpeed: 50,
    loop: true
  });
  return () => typed.destroy();  

});

};


