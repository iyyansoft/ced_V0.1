      { "question": "Where can I find the Impact Reports?", "keywords": "report impact yearly statistics milestones", "answer": "📊 Our comprehensive yearly Impact Reports (including 2023-24 and 2024-25), which detail the massive number of startups we've helped, are available under the <strong>'Milestones'</strong> section in the main navigation menu." }
    ]
  };

  const cedCorpus = [];
  Object.entries(cedFaqData).forEach(([cat, questions]) => {
    questions.forEach(q => cedCorpus.push({
      text: (q.question + " " + q.answer + " " + (q.keywords || "") + " " + cat).toLowerCase(),
      question: q.question,
      answer: q.answer,
      category: cat,
      keywords: q.keywords || ""
    }));
  });

  function cedGetTermFrequency(text) {
    const words = text.match(/\b(\w+)\b/g) || [];
    const tf = {};
    words.forEach(w => { tf[w] = (tf[w] || 0) + 1; });
    return { tf, length: words.length };
  }

  const cedIdf = {};
  cedCorpus.forEach(doc => {
    const uniqueWords = new Set((doc.text.match(/\b(\w+)\b/g) || []));
    uniqueWords.forEach(w => { cedIdf[w] = (cedIdf[w] || 0) + 1; });
  });

  const cedTotalDocs = cedCorpus.length;
  for (let w in cedIdf) {
    cedIdf[w] = Math.log(cedTotalDocs / cedIdf[w]);
  }

  function cedGetVector(text) {
    const { tf, length } = cedGetTermFrequency(text.toLowerCase());
    const vec = {};
    for (let w in tf) {
      if (cedIdf[w]) vec[w] = (tf[w] / length) * cedIdf[w];
    }
    return vec;
  }

  function cedCosineSimilarity(vec1, vec2) {
    let dotProduct = 0;
    let mag1 = 0;
    let mag2 = 0;
    for (let w in vec1) {
      if (vec2[w]) dotProduct += vec1[w] * vec2[w];
      mag1 += vec1[w] * vec1[w];
    }
    for (let w in vec2) {
      mag2 += vec2[w] * vec2[w];
    }
    if (mag1 === 0 || mag2 === 0) return 0;
    return dotProduct / (Math.sqrt(mag1) * Math.sqrt(mag2));
  }

  function cedAppendChatConversation(queryText, answerText, isUserOnly = false) {
    const history = document.getElementById("cedChatConversationHistory");
    const emptyState = history.querySelector(".history-empty");
    if (emptyState) emptyState.remove();

    const oldTyping = history.querySelector(".typing-indicator");
    if (oldTyping) oldTyping.parentElement.remove();

    if (isUserOnly) {
      const message = document.createElement("div");
      message.className = "message";
      const userBubble = document.createElement("div");
      userBubble.className = "message-user";
      userBubble.textContent = queryText;
      message.appendChild(userBubble);
      
      const typingMsg = document.createElement("div");
      typingMsg.className = "message";
      typingMsg.innerHTML = '<div class="message-assistant typing-indicator"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
      
      history.appendChild(message);
      history.appendChild(typingMsg);
      typingMsg.scrollIntoView({ behavior: "smooth", block: "end" });
      return;
    }

    const message = document.createElement("div");
    message.className = "message";
    
    if (queryText && answerText) {
      const userBubble = document.createElement("div");
      userBubble.className = "message-user";
      userBubble.textContent = queryText;
      message.appendChild(userBubble);
    }

    const assistantBubble = document.createElement("div");
    assistantBubble.className = "message-assistant";
    assistantBubble.innerHTML = answerText;
    
    message.appendChild(assistantBubble);
    history.appendChild(message);
    message.scrollIntoView({ behavior: "smooth", block: "end" });
  }

  function cedSetChatOpen(isOpen) {
    const widget = document.getElementById("cedChatWidget");
    widget.classList.toggle("hidden", !isOpen);
    if (isOpen) {
      setTimeout(() => document.getElementById("cedChatSearchInput").focus(), 100);
    }
  }

  function cedHandleChatSearch(query) {
    const trimmed = query.trim().toLowerCase();
    if (!trimmed) return;
    document.getElementById("cedChatSearchInput").value = "";

    cedAppendChatConversation(query, null, true);

    setTimeout(() => {
      const queryVec = cedGetVector(trimmed);
      let bestMatch = null;
      let highestScore = 0;

      cedCorpus.forEach(doc => {
        const docVec = cedGetVector(doc.text);
        let score = cedCosineSimilarity(queryVec, docVec);
        
        // Massive boost for exact phrase match in question, category, or keywords
        if (doc.question.toLowerCase().includes(trimmed) || 
            doc.category.toLowerCase().includes(trimmed) || 
            doc.keywords.toLowerCase().includes(trimmed)) {
          score += 2.0;
        }

        const stopWords = ["what", "are", "the", "is", "for", "and", "to", "in", "of", "how", "do", "i", "a", "an", "all", "can", "you", "my", "we", "on", "where", "who", "when", "why", "it", "that", "this", "there", "their", "ced"];
        const queryWords = trimmed.match(/\b(\w+)\b/g) || [];
        
        queryWords.forEach(w => {
           if (stopWords.includes(w)) return; // Ignore common words
           
           // Small boost for matching important keywords inside the question
           if(w.length > 2 && doc.question.toLowerCase().includes(w)) score += 0.4;
           // Tiny boost for matching words inside the answer
           if(w.length > 3 && doc.answer.toLowerCase().includes(w)) score += 0.15;
        });

        if (score > highestScore) {
          highestScore = score;
          bestMatch = doc;
        }
      });

      if (bestMatch && highestScore > 0.15) { 
        const formattedAnswer = `<strong style="font-size:1.05rem; color:#d81b8c;">${bestMatch.question}</strong><br><br><span style="line-height:1.6; color:#374151;">${bestMatch.answer}</span>`;
        cedAppendChatConversation(null, formattedAnswer, false);
      } else {
        cedAppendChatConversation(null, "I couldn't find an exact match for that. Please try exploring the menus at the top, or contact us directly at cedau.outreach@gmail.com.", false);
      }
    }, 600);
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("cedChatSearchButton")?.addEventListener("click", () => {
      cedHandleChatSearch(document.getElementById("cedChatSearchInput").value);
    });
    
    document.getElementById("cedChatSearchInput")?.addEventListener("keydown", (event) => {
      if (event.key === "Enter") cedHandleChatSearch(document.getElementById("cedChatSearchInput").value);
    });

    document.getElementById("cedChatLauncher")?.addEventListener("click", () => {
      const isOpen = document.getElementById("cedChatWidget").classList.contains("hidden");
      cedSetChatOpen(isOpen);
    });
    
    document.getElementById("cedCloseChatButton")?.addEventListener("click", () => {
      cedSetChatOpen(false);
    });

    document.querySelectorAll("#cedQuickSuggestions .quick-chip").forEach(chip => {
      chip.addEventListener("click", () => {
        cedHandleChatSearch(chip.textContent);
      });
    });
  });
</script>
