<script>
  document.addEventListener("shown.bs.collapse", function () {
    document.body.style.overflow = "hidden";
  });

  document.addEventListener("hidden.bs.collapse", function () {
    document.body.style.overflow = "auto";
  });
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const nav = document.getElementById("navigation");

  nav.addEventListener("shown.bs.collapse", () => {
    document.body.style.overflow = "hidden";
  });

  nav.addEventListener("hidden.bs.collapse", () => {
    document.body.style.overflow = "auto";
  });

  document.querySelectorAll("[data-mobile-toggle]").forEach(toggle => {

    toggle.addEventListener("click", e => {
      e.preventDefault();

      if (window.innerWidth >= 992) return;

      const menu = toggle.nextElementSibling;
      if (!menu) return;

      document.querySelectorAll(".dropdown-menu.show")
        .forEach(d => {
          if (d !== menu) d.classList.remove("show");
        });

      menu.classList.toggle("show");

      menu.scrollIntoView({
        behavior: "smooth",
        block: "start"
      });
    });

  });

});
</script>




