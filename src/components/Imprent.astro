  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:32px;
  margin-top:20px;
}

/* ===== TEMPLATE CARD ===== */
.template-card{
  background:#ffffff;
  padding:42px 36px;
  border-radius:30px;
  box-shadow:0 22px 55px rgba(0,0,0,.1);
  position:relative;
  transition:.35s ease;
  overflow:hidden;
}

/* top light-green strip */
.template-card::before{
  content:"";
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:8px;
  background:linear-gradient(90deg,#86efac,#22c55e);
}

/* badge */
.template-badge{
  display:inline-block;
  background:#dcfce7;
  color:#15803d;
  font-size:13px;
  font-weight:800;
  padding:6px 14px;
  border-radius:14px;
  margin-bottom:18px;
}

/* heading */
.template-card h3{
  font-size:22px;
  font-weight:900;
  color:#15803d;
  margin-bottom:18px;
}

/* list */
.template-card ul{
  padding-left:20px;
}

.template-card li{
  margin-bottom:10px;
  color:#334155;
  font-weight:600;
}

/* hover effect */
.template-card:hover{
  transform:translateY(-8px);
  box-shadow:0 35px 90px rgba(0,0,0,.15);
}

/* mobile */
@media(max-width:900px){
  .template-grid{
    grid-template-columns:1fr;
  }
}


/* ================= SUBMISSION SECTION ================= */
/* ================= SUBMISSION – DARK (COMPACT) ================= */
.submission-dark{
  position:relative;
  padding:60px 60px;   /* height reduced */
  overflow:hidden;

  background:
    radial-gradient(circle at 15% 25%, rgba(34,197,94,.18), transparent 45%),
    radial-gradient(circle at 85% 75%, rgba(22,163,74,.18), transparent 50%),
    linear-gradient(135deg, #020617, #000000);
}

/* animated background blobs */
.submission-dark::before,
.submission-dark::after{
  content:"";
  position:absolute;
  width:420px;
  height:420px;
  background:#022c22;
  filter:blur(150px);
  opacity:.5;
  z-index:0;
  animation:darkFloat 20s ease-in-out infinite;
}

.submission-dark::before{
  top:-180px;
  left:-180px;
}

.submission-dark::after{
  bottom:-180px;
  right:-180px;
  animation-delay:6s;
}

@keyframes darkFloat{
  0%{transform:translate(0,0)}
  50%{transform:translate(90px,70px)}
  100%{transform:translate(0,0)}
}

/* keep content above bg */
.submission-dark > *{
  position:relative;
  z-index:2;
}

/* ================= HEADING ================= */
.submission-dark h2{
  text-align:center;
  font-size:32px;
  font-weight:900;
  letter-spacing:1px;
  color:#f8fafc;
  margin-bottom:40px; /* reduced */
}

/* ================= GRID ================= */
.submission-progress{
  max-width:900px;
  margin:0 auto;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:22px;   /* compact */
}

/* ================= CARD ================= */
.progress-item{
  display:flex;
  align-items:center;
  gap:18px;

  background:rgba(255,255,255,.06);
  backdrop-filter:blur(14px);

  padding:22px 30px;  /* reduced height */
  border-radius:26px;
  border-left:6px solid #22c55e;

  box-shadow:0 22px 60px rgba(0,0,0,.7);
  transition:.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  transform-style:preserve-3d;
}

.progress-item:hover{
  transform:translateY(-10px) scale(1.03) rotateX(5deg) rotateY(-5deg);
  box-shadow:-15px 45px 120px rgba(0,0,0,.9);
}

/* ================= ICON ================= */
.progress-icon{
  width:48px;
  height:48px;
  border-radius:50%;

  background:rgba(34,197,94,.15);
  color:#22c55e;
  font-size:22px;

  display:flex;
  align-items:center;
  justify-content:center;

  border:2px solid rgba(34,197,94,.45);
  box-shadow:0 0 16px rgba(34,197,94,.4);
}

/* ================= TEXT ================= */
.progress-item p{
  font-size:16px;
  font-weight:800;
  color:#e5e7eb;
}

/* ================= MOBILE ================= */
@media(max-width:900px){
  .submission-progress{
    grid-template-columns:1fr;
  }

  .submission-dark{
    padding:50px 20px;
  }
}

</style>
