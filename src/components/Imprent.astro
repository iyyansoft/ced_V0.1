<script>
document.querySelectorAll(".acc-head").forEach(head => {
  head.addEventListener("click", () => {
    const accordion = head.parentElement;
    const body = accordion.querySelector(".acc-body");

    // close others (optional – remove if not needed)
    document.querySelectorAll(".accordion").forEach(item => {
      if(item !== accordion){
        item.classList.remove("active");
        item.querySelector(".acc-body").style.maxHeight = null;
      }
    });

    // toggle current
    accordion.classList.toggle("active");

    if(accordion.classList.contains("active")){
      body.style.maxHeight = body.scrollHeight + "px"; // ✅ FULL HEIGHT
    }else{
      body.style.maxHeight = null;
    }
  });
});



  const text = "IMPRENT";
  const target = document.getElementById("imprentType");
  let index = 0;

  function typeLoop(){
    if(index < text.length){
      target.textContent += text[index];
      index++;
    }else{
      target.textContent = "";
      index = 0;
    }
  }

  setInterval(typeLoop, 250); // typing speed

</script>


