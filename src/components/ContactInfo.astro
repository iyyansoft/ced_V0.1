---
// ContactInfo.astro
---
<section class="py-5 bg-light">
  <div class="container">
    <div class="row text-center g-4">

      <!-- Email -->
      <div class="col-md-3">
        <div class="contact-card h-100">
          <i class="bi bi-envelope-fill contact-icon"></i>
          <h6>Email</h6>
          <p>dirced@annauniv.edu</p>
        </div>
      </div>

      <!-- Phone -->
      <div class="col-md-3">
        <div class="contact-card h-100">
          <i class="bi bi-telephone-fill contact-icon"></i>
          <h6>Phone</h6>
          <p>044 2235 9290 / 9289</p>
        </div>
      </div>

      <!-- Contact Person -->
      <div class="col-md-3">
        <div class="contact-card h-100">
          <i class="bi bi-person-fill contact-icon"></i>
          <h6>Contact</h6>
          <p>The Director, CED</p>
        </div>
      </div>

      <!-- Address -->
      <div class="col-md-3">
        <div class="contact-card h-100">
          <i class="bi bi-geo-alt-fill contact-icon"></i>
          <h6>Address</h6>
          <p class="small">
            302, 2nd Floor, Platinum Jubilee Building,<br>
            AC Tech Campus, Anna University,<br>
            Guindy, Chennai – 600025
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="py-5 bg-white">
  <div class="container">

    <!-- ROW CENTER -->
    <div class="row justify-content-center">

      <!-- COLUMN CENTER -->
      <div class="col-lg-8 col-md-10 col-12 mx-auto">

        <!-- FORM CARD -->
        <div class="contact-form-card p-5 mx-auto">

          <h3 class="text-center fw-bold mb-4">
            Get in Touch
          </h3>

          <form>
            <div class="row g-3">

              <div class="col-md-6">
                <label class="form-label">Your Name</label>
                <input type="text" class="form-control" placeholder="Enter your name">
              </div>

              <div class="col-md-6">
                <label class="form-label">Email Address</label>
                <input type="email" class="form-control" placeholder="Enter your email">
              </div>

              <div class="col-md-6">
                <label class="form-label">Phone Number</label>
                <input type="tel" class="form-control" placeholder="Enter phone number">
              </div>

              <div class="col-md-6">
                <label class="form-label">Subject</label>
                <input type="text" class="form-control" placeholder="Subject">
              </div>

              <div class="col-12">
                <label class="form-label">Message</label>
                <textarea class="form-control" rows="4" placeholder="Write your message..."></textarea>
              </div>

              <div class="col-12 text-center mt-4">
                <button type="submit" class="btn btn-primary px-5 py-2">
                  Send Message
                </button>
              </div>

            </div>
          </form>

        </div>
      </div>

    </div>
  </div>
</section>




<style>
/* Contact cards */
.contact-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 25px 15px;
  box-shadow: 0 15px 35px rgba(0,0,0,0.08);
  transition: transform 0.3s ease;
}

.contact-card:hover {
  transform: translateY(-6px);
}

.contact-icon {
  font-size: 32px;
  color: #0d6efd;
  margin-bottom: 10px;
}

/* Contact form */
.contact-form-card {
  background: #f8f9fa;
  border-radius: 20px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}
</style>