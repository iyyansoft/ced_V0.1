---
// iic-anna-university-page.astro – OPTION 3 THEME (White Main + Blue Accents)
// Clean • Modern • Corporate • Premium
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>IIC – Anna University | Clean White Premium Theme</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet" />

  <style>
    :root {
      --blue-primary: #0b5cff;
      --blue-dark: #002c70;
      --blue-soft: #77b5ff;
      --bg-light: #ffffff;
      --text-dark: #1a1a1a;
      --card-shadow: 0 8px 24px rgba(0,0,0,0.08);
      --radius: 18px;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
    }

    /* HERO SECTION – Only this is Blue */
    .hero {
      background: linear-gradient(135deg, var(--blue-dark), var(--blue-primary));
      color: white;
      padding: 80px 20px;
      border-bottom-left-radius: 40px;
      border-bottom-right-radius: 40px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.15);
      text-align: center;
    }

    .hero-badge {
      display: inline-block;
      background: white;
      color: var(--blue-primary);
      padding: 10px 22px;
      border-radius: 999px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .hero-title {
      font-size: clamp(36px, 6vw, 58px);
      font-weight: 600;
    }

    .hero-sub {
      font-size: 1.2rem;
      opacity: 0.95;
    }

    /* PAGE WRAPPER */
    .wrapper {
      max-width: 1100px;
      margin: 40px auto;
      padding: 0 20px;
    }

    /* SECTION HEADERS */
    .section-title {
      font-size: 32px;
      font-weight: 800;
      color: var(--blue-dark);
      margin-top: 50px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .stripe {
      width: 80px;
      height: 6px;
      background: var(--blue-primary);
      border-radius: 6px;
    }

    /* WHITE CARDS */
    .white-card {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--card-shadow);
      border: 1px solid #e7e7e7;
      margin-top: 16px;
    }

    /* INFO CARDS */
    .info-card {
      background: white;
      border: 1px solid #eaeaea;
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--card-shadow);
      transition: 0.25s ease;
    }

    .info-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(0,0,0,0.12);
    }

    footer {
      text-align: center;
      margin-top: 60px;
      padding: 20px;
      color: #555;
      font-size: 0.95rem;
    }


    /* =====================================================
   GLOBAL MOBILE SAFETY
===================================================== */
html, body {
  overflow-x: hidden;
}

/* =====================================================
   HERO SECTION – MOBILE FIX
===================================================== */
@media (max-width: 768px) {

  .hero {
    padding: 50px 16px;
    border-radius: 0 0 28px 28px;
  }

  .hero .row {
    text-align: center;
  }

  .hero-title {
    font-size: 30px;
  }

  .hero-sub {
    font-size: 1rem;
  }

  .hero-image-box {
    width: 240px;
    height: 180px;
    margin: 0 auto 20px;
  }
}

/* =====================================================
   WRAPPER & SECTIONS – MOBILE SPACING
===================================================== */
@media (max-width: 768px) {

  .wrapper {
    margin: 24px auto;
    padding: 0 14px;
  }

  .section-title {
    font-size: 22px;
    margin-top: 36px;
  }

  .stripe {
    width: 50px;
    height: 4px;
  }

  .white-card {
    padding: 16px;
    font-size: 0.95rem;
  }
}

/* =====================================================
   INFO CARDS – SINGLE COLUMN
===================================================== */
@media (max-width: 768px) {

  .row.g-4 > div {
    flex: 0 0 100%;
    max-width: 100%;
  }

  .info-card {
    padding: 16px;
  }

  .info-card h6 {
    font-size: 1rem;
  }

  .info-card ul {
    padding-left: 18px;
    font-size: 0.95rem;
  }
}

/* =====================================================
   TABLES – MOBILE FRIENDLY SCROLL
===================================================== */
@media (max-width: 768px) {

  table {
    min-width: 700px; /* enables horizontal scroll */
  }

  .table-responsive,
  .table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  th, td {
    font-size: 0.9rem;
    white-space: normal;
  }
}

/* =====================================================
   BADGES & TEXT
===================================================== */
@media (max-width: 768px) {

  .badge {
    font-size: 0.8rem;
    padding: 6px 10px;
  }
}


/* =====================================================
   MOBILE TABLE – FINAL FIX
===================================================== */
@media (max-width: 768px) {

  /* wrapper scroll */
  .table-responsive-mobile {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* force table width */
  .table-responsive-mobile table {
    min-width: 720px;   /* 👈 VERY IMPORTANT */
    border-collapse: separate;
  }

  /* header readability */
  .table-responsive-mobile thead th {
    font-size: 13px;
    white-space: nowrap;
    text-align: center;
    vertical-align: middle;
  }

  /* body cells */
  .table-responsive-mobile td {
    font-size: 12px;
    line-height: 1.4;
    vertical-align: top;
    white-space: normal;
  }

  /* innovation title column */
  .table-responsive-mobile td:nth-child(2) {
    min-width: 220px;
  }

  /* theme column */
  .table-responsive-mobile td:nth-child(3) {
    min-width: 200px;
  }

  /* innovator column */
  .table-responsive-mobile td:nth-child(4) {
    min-width: 200px;
  }

  /* result column */
  .table-responsive-mobile td:nth-child(5) {
    min-width: 120px;
    text-align: center;
  }
}


  </style>
</head>

