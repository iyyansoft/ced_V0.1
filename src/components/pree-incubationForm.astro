<script is:inline>
let allApplications = [];

document.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("cedForm");
  const formMsg = document.getElementById("formMsg");
  const submitBtn = form.querySelector("button[type='submit']");

  const nameErr   = document.getElementById("nameErr");
  const mobileErr = document.getElementById("mobileErr");
  const emailErr  = document.getElementById("emailErr");
  const dpiitErr  = document.getElementById("dpiitErr");
  const udyamErr  = document.getElementById("udyamErr");
 
  const photoErr  = document.getElementById("photoErr");

  if (!form || !formMsg) return;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    let valid = true;

    const name   = document.getElementById("name");
    const mobile = document.getElementById("mobile");
    const email  = document.getElementById("email");
    const dpiit  = document.getElementById("dpiit");
    const udyam  = document.getElementById("udyam");
    const pptLink = document.getElementById("ppt");
    const pptLinkErr = document.getElementById("pptLinkErr");

    const photoUpload = document.getElementById("photo");

    const dpiitPattern = /^(DIPP|DPIIT)\d{5,7}$/;
    const udyamPattern = /^UDYAM-[A-Z]{2}-\d{2}-\d{7}$/;

    // Clear errors
    [nameErr,mobileErr,emailErr,dpiitErr,udyamErr,pptLinkErr,photoErr]
.forEach(el => el.innerHTML = "");
    [name,mobile,email,dpiit,udyam].forEach(el => el.classList.remove("error-border"));

    // Validation
    if(!name.value.trim()){ valid=false; nameErr.innerHTML="Enter Name"; name.classList.add("error-border"); }
    if(!/^\d{10}$/.test(mobile.value.trim())){ valid=false; mobileErr.innerHTML="10 digit mobile only"; mobile.classList.add("error-border"); }
    if(!/^[a-zA-Z0-9._%+-]+@gmail\.com$/.test(email.value.trim())){ valid=false; emailErr.innerHTML="Only Gmail allowed"; email.classList.add("error-border"); }
   
    if(!pptLink.value.trim()){
     valid=false;
     pptLinkErr.innerHTML="Paste Google Drive PPT link";
}
    if(!photoUpload.files.length){ valid=false; photoErr.innerHTML="Upload Photo"; }

    if(!valid) return;

    submitBtn.disabled = true;
    submitBtn.innerText = "Saving...";

    // ---------- FORM DATA ----------
    const formData = new FormData(form);

// 🔥 Force role field append
const roleValue = document.getElementById("role").value;
formData.set("role", roleValue);

// 🔥 Fix services checkbox
formData.delete("services[]");
document.querySelectorAll('input[name="services[]"]:checked')
.forEach(cb => {
  formData.append("services[]", cb.value);
});



 


  

  const API_URL =
  location.hostname === "localhost"
    ? "http://localhost:8000"
    : "https://ced-backend-7uwz.onrender.com";


    try{
      

      const res = await fetch(`${API_URL}/api/preincubation`, {
      method: "POST",
      body: formData
      });



      const data = await res.json();

      if(res.ok){

        formMsg.style.color = "green";
        formMsg.innerHTML = "✔ Data Saved Successfully!";
        form.reset();
      }else{
        throw new Error("Save Failed");
      }

    }catch(err){
      console.log(err);
      formMsg.style.color="red";
      formMsg.innerHTML="✖ Save Failed!";
    }finally{
      submitBtn.disabled = false;
      submitBtn.innerText = "Submit";
    }
  });

});
</script>



















