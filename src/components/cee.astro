<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI',sans-serif;
}

/* ================= PAGE ================= */
body{
  background:#ffffff;
  color:#1f2937;
  overflow-x:hidden;
}

/* ================= HERO ================= */
.hero{
  padding:70px 6% 40px;
  text-align:center;
  position:relative;
  z-index:10;
}

.hero h1 {
  font-size: 36px;
  background: linear-gradient(90deg, #E60073, #ff4da6);
  -webkit-background-clip: text;
  color: transparent;
  font-weight: 700;
}




/* ================= LAYOUT ================= */
.wrapper{
  position:relative;
  z-index:10;   /* flowers mela content */
  display:grid;
  grid-template-columns:260px 1fr;
  gap:40px;
  padding:40px 6% 80px;
}

/* ================= SIDEBAR ================= */
.sidebar{
  background:linear-gradient(180deg,#1e293b,#020617);
  color:#fff;
  border-radius:22px;
  padding:22px;
  height:520px;
          /* Full screen height */
  overflow-y: auto;       /* Vertical scroll enable */
  position: sticky;       /* Optional – fixed like sidebar */
  top: 0;
}



.sidebar h3{
  margin-bottom: 25px;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 3px;
  color: #ffffff;
  text-align: center;
  position: relative;
}

.sidebar h3::after{
  content: "";
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: -8px;
  width: 70px;
  height: 4px;
  background: linear-gradient(90deg,#ec4899,#f43f5e);
  border-radius: 10px;
  box-shadow: 0 0 10px #ec4899;
}


.batch-link{
  padding:14px 16px;
  margin-bottom:12px;
  border-radius:14px;
  cursor:pointer;
  background:rgba(255,255,255,.12);
  transition:.3s;
}

.batch-link:hover{
  transform:translateX(6px);
}

.batch-link.active{
  background:linear-gradient(135deg,#ec4899,#f43f5e);
  font-weight:700;
}

/* ================= CONTENT (SCROLL INSIDE) ================= */
.content{
  background:linear-gradient(180deg,#1f2937,#020617);
  color:#fff;
  border-radius:28px;
  padding:34px;

  height:520px;        /* 🔥 fixed */
  overflow-y:auto;     /* 🔥 inner scroll */
}

/* scrollbar */
.content::-webkit-scrollbar{width:6px;}
.content::-webkit-scrollbar-thumb{
  background:#ec4899;
  border-radius:10px;
}

/* ================= BATCH ================= */
.batch-content{display:none;}
.batch-content.active{display:block;}

/* ================= TITLE ================= */
.batch-title{
  font-size:22px;
  margin-bottom:26px;
  padding-left:14px;
  border-left:5px solid #f472b6;
}

/* ================= LIST ================= */
.edu-item{
  padding:18px 22px;
  margin-bottom:18px;
  border-radius:18px;
  background:rgba(255,255,255,.12);
  transition:.3s;
}

.edu-item:hover{
  transform:translateX(10px);
  background:linear-gradient(90deg,#fbcfe8,#fecdd3);
  color:#020617;
}

.edu-name{font-weight:700;}
.edu-inst{font-size:14px;opacity:.9;}

/* ================= MOBILE ================= */
@media(max-width:900px){
  .wrapper{grid-template-columns:1fr;}
  .content{height:65vh;}
}


.wave-text {
  font-size: 42px;
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  background: linear-gradient(
    270deg,
    #c2185b,
    #E60073,
    #ff66b2,
    #E60073,
    #c2185b
  );
  background-size: 400% 400%;
  -webkit-background-clip: text;
  color: transparent;
  animation: gradientWave 6s ease infinite;
}

@keyframes gradientWave {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}



</style>



</head>

