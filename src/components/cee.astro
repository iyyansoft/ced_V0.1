<script>
document.querySelectorAll('.batch-link').forEach(link=>{
  link.onclick=()=>{
    document.querySelectorAll('.batch-link').forEach(l=>l.classList.remove('active'));
    document.querySelectorAll('.batch-content').forEach(c=>c.classList.remove('active'));
    link.classList.add('active');
    document.getElementById(link.dataset.batch).classList.add('active');
  };
});
</script>

