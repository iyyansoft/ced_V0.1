<style>

/* HERO SECTION */

/* HERO IMAGE */

.makers-hero{
height:90vh;
background-image:url("../assets/img/makerslabimg.jpeg");
background-size:cover;
background-position:center;

}

/* TEXT SECTION */

.hero-text{
text-align:center;
padding:61px 20px;
max-width:900px;
margin:auto;
}

.hero-badge{
display:inline-block;
padding:6px 14px;
background:#7C3AED;
color:white;
border-radius:20px;
font-size:14px;
margin-bottom:20px;
}

.hero-text h1{
font-size:42px;
color:#7C3AED;
margin-bottom:20px;
}

.hero-text p{
font-size:18px;
line-height:1.7;
color:#555;
}







/* TABLE SECTION */

.facility-section{
padding:50px 8%;
background:#f5f7fb;
}


/* TABLE SCROLL CONTAINER */

.facility-table-wrapper{
height:500px;
overflow-y:auto;
background:white;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}


/* TABLE */

.facility-table{
width:100%;
border-collapse:collapse;
font-family:"Segoe UI", sans-serif;
}


/* STICKY HEADER */

.facility-table th{
position: sticky;
top: 0;

background:linear-gradient(90deg,#ffe4ef,#f8c6da);

color:#333;
padding:14px;
text-align:left;
font-weight:600;
}


/* BODY CELLS */

.facility-table td{
padding:18px;
border-bottom:1px solid #eee;
vertical-align:top;
color:#444;
}


/* SPEC COLUMN */

.spec{
font-size:14px;
line-height:1.7;
}


/* ROW HOVER */

.facility-table tbody tr:hover{
background:#f3f6ff;
}


/* COLUMN WIDTHS */

.facility-table th:nth-child(1){width:80px;}
.facility-table th:nth-child(2){width:220px;}
.facility-table th:nth-child(3){width:220px;}
.facility-table th:nth-child(4){width:500px;}
.facility-table th:nth-child(5){width:100px;}
.facility-table th:nth-child(6){width:80px;}
.facility-table th:nth-child(7){width:200px;}


/* MOBILE */

@media(max-width:1000px){

.facility-table{
min-width:1100px;
}

.facility-table-wrapper{
overflow-x:auto;
}

.hero-content h1{
font-size:32px;
}

}

</style>