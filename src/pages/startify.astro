---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Startify">
  <div style="
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 3rem;
    font-family: 'Arial', sans-serif;
    text-align: center;
    background: linear-gradient(135deg, rgba(45,34,80,0.8), rgba(26,24,51,0.9));
    overflow: hidden;
  ">

    <!-- Glass Effect Card -->
    <div style="
      position: relative;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 2rem;
      padding: 2rem 2rem 1.5rem 2rem;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      width: 100%;
      max-width: 1400px;
    ">

      <!-- Header Section -->
      <div style="
        width: 100%;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
      ">
        <div style="
          width: 200px;
          height: 60px;
          margin: 0 auto 1rem;
          background: linear-gradient(45deg, #a18fff, #ff6b9d);
          border-radius: 15px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 1.8rem;
          font-weight: bold;
          color: white;
          text-shadow: 0 0 20px rgba(161, 143, 255, 0.5);
        ">
          STARTIFY
        </div>
        <h1 style="
          font-size: 2.5rem;
          margin-bottom: 0.5rem;
          font-weight: 700;
          background: linear-gradient(45deg, #a18fff, #ff6b9d, #4facfe);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        ">
          STARTIFY 3.0
        </h1>
        <p style="font-size: 1.2rem; opacity: 0.8; color: #e0e0ff;">
          List of Registered Ideas (Students & Faculty)
        </p>
      </div>

      <!-- Stats Grid -->
      <div style="
        width: 100%;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
      ">
        <div style="
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          background: rgba(255, 255, 255, 0.08);
          border: 1px solid rgba(255, 255, 255, 0.15);
          border-radius: 1.5rem;
          padding: 2rem;
          text-align: center;
          box-shadow: 0 8px 32px rgba(0,0,0,0.2);
          position: relative;
          overflow: hidden;
        ">
          <div style="font-size: 2.5rem; font-weight: bold; background: linear-gradient(45deg, #a18fff, #4facfe); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem;" id="totalEntries">1587</div>
          <div style="color: #e0e0ff; font-size: 1rem; opacity: 0.9;">Total Entries</div>
        </div>
        <div style="
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          background: rgba(255, 255, 255, 0.08);
          border: 1px solid rgba(255, 255, 255, 0.15);
          border-radius: 1.5rem;
          padding: 2rem;
          text-align: center;
          box-shadow: 0 8px 32px rgba(0,0,0,0.2);
          position: relative;
          overflow: hidden;
        ">
          <div style="font-size: 2.5rem; font-weight: bold; background: linear-gradient(45deg, #a18fff, #4facfe); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem;" id="totalColleges">150+</div>
          <div style="color: #e0e0ff; font-size: 1rem; opacity: 0.9;">Participating Colleges</div>
        </div>
        <div style="
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          background: rgba(255, 255, 255, 0.08);
          border: 1px solid rgba(255, 255, 255, 0.15);
          border-radius: 1.5rem;
          padding: 2rem;
          text-align: center;
          box-shadow: 0 8px 32px rgba(0,0,0,0.2);
          position: relative;
          overflow: hidden;
        ">
          <div style="font-size: 2.5rem; font-weight: bold; background: linear-gradient(45deg, #a18fff, #4facfe); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem;" id="totalDistricts">25+</div>
          <div style="color: #e0e0ff; font-size: 1rem; opacity: 0.9;">Districts Covered</div>
        </div>
      </div>

      <!-- Download PDF Button -->
      <div style="
        width: 100%;
        display: flex;
        justify-content: center;
        margin-bottom: 2rem;
      ">
        <button id="downloadPdfBtn" style="
          background: linear-gradient(45deg, #a18fff, #ff6b9d);
          border: none;
          border-radius: 15px;
          padding: 0.75rem 1.5rem;
          color: white;
          font-size: 1rem;
          font-weight: 600;
          cursor: pointer;
          transition: all 0.3s ease;
          box-shadow: 0 4px 15px rgba(161, 143, 255, 0.3);
          text-transform: uppercase;
          letter-spacing: 0.5px;
        " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(161, 143, 255, 0.4)'" 
           onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(161, 143, 255, 0.3)'">
          📄 Download List Of Registered Ideas(Students & Faculties)
        </button>
      </div>

      <!-- Footer -->
      <div style="
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
        width: 100%;
      ">
        <p style="color: #4facfe; font-weight: 500;">For any queries related to Team ID, Team Members, College Name, or District, please contact us at <a href="mailto:cedau.outreach@gmail.com" style="color: #ff6b9d; text-decoration: none; font-weight: 600;">cedau.outreach@gmail.com</a></p>
        <p style="margin-top: 0.5rem; font-size: 0.9rem; color: #a18fff; font-weight: 500;">All queries must be submitted only through email; no other modes of communication will be entertained.</p>
      </div>
    </div>

    <!-- Soft Glowing Circles for Depth -->
    <div style="
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, #a18fff 0%, transparent 70%);
      top: -10%;
      left: -10%;
      filter: blur(120px);
      z-index: 0;
    "></div>
    <div style="
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, #ff6b9d 0%, transparent 70%);
      bottom: -15%;
      right: -15%;
      filter: blur(140px);
      z-index: 0;
    "></div>

  </div>

  <style is:global>
    @media (max-width: 768px) {
      /* Mobile responsive adjustments */
      div[style*="padding: 3rem"] {
        padding: 1.5rem !important;
      }
      
      div[style*="max-width: 1400px"] {
        padding: 1.5rem !important;
        border-radius: 1.5rem !important;
      }
      
      h1[style*="font-size: 2.5rem"] {
        font-size: 2rem !important;
      }
      
      p[style*="font-size: 1.2rem"] {
        font-size: 1rem !important;
      }
      
      /* Stats grid - single column on mobile */
      div[style*="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr))"] {
        grid-template-columns: 1fr !important;
        gap: 1rem !important;
      }
      
      /* Download button responsive */
      #downloadPdfBtn {
        font-size: 0.9rem !important;
        padding: 0.6rem 1.2rem !important;
        width: 100% !important;
        max-width: 280px !important;
      }
      
      /* Footer responsive */
      div[style*="padding: 2rem"] {
        padding: 1.5rem !important;
      }
      
      /* Path notification responsive */
      div[style*="max-width: 300px"] {
        max-width: calc(100vw - 40px) !important;
        font-size: 0.8rem !important;
      }
    }
    
    @media (max-width: 480px) {
      /* Extra small mobile adjustments */
      div[style*="padding: 1.5rem"] {
        padding: 1rem !important;
      }
      
      h1[style*="font-size: 2rem"] {
        font-size: 1.8rem !important;
      }
      
      /* Logo responsive */
      div[style*="width: 200px; height: 60px"] {
        width: 150px !important;
        height: 50px !important;
        font-size: 1.4rem !important;
      }
      
      /* Stats cards smaller */
      div[style*="padding: 2rem"] {
        padding: 1.5rem !important;
      }
      
      div[style*="font-size: 2.5rem"] {
        font-size: 2rem !important;
      }
      
      #downloadPdfBtn {
        font-size: 0.8rem !important;
        padding: 0.6rem 1rem !important;
      }
    }

    @media (max-width: 600px) {
      p {
        font-size: 1.1rem !important;
        max-width: 95vw !important;
      }
      .logo {
        width: 120px !important;
        height: 40px !important;
        font-size: 1.2rem !important;
        margin-bottom: 0.75rem !important;
      }
      h1 {
        font-size: 1.5rem !important;
        margin-bottom: 0.5rem !important;
      }
      a[download] {
        font-size: 1rem !important;
        padding: 0.7rem 1.5rem !important;
      }
      #downloadPdfBtn {
        font-size: 0.9rem !important;
        padding: 0.6rem 1.2rem !important;
      }
    }
    
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px);}
      to { opacity: 1; transform: translateY(0);}
    }
  </style>

  <script type="text/javascript" is:inline>
    // PDF Download Function
    function downloadPDF() {
      // Show loading state
      const btn = document.getElementById('downloadPdfBtn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '⏳ Downloading PDF...';
      btn.disabled = true;
      
      // Create a temporary element to show the download notification
      const pathElement = document.createElement('div');
      pathElement.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: rgba(161, 143, 255, 0.9);
        color: white;
        padding: 1rem;
        border-radius: 10px;
        font-size: 0.9rem;
        z-index: 1000;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        max-width: 300px;
        word-wrap: break-word;
      `;
      pathElement.innerHTML = `📁 Downloading PDF:<br><strong>startify.pdf</strong>`;
      document.body.appendChild(pathElement);
      
      setTimeout(() => {
        // Create download link for the PDF
        const a = document.createElement('a');
        a.style.display = 'none';
        a.href = '/assets/pdf/startify.pdf';
        a.download = 'startify.pdf';
        a.target = '_blank';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);

        // Reset button and remove notification
        btn.innerHTML = originalText;
        btn.disabled = false;
        
        // Remove notification element after 5 seconds
        setTimeout(() => {
          if (pathElement && pathElement.parentNode) {
            document.body.removeChild(pathElement);
          }
        }, 5000);
      }, 1000);
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', function() {
      document.getElementById('downloadPdfBtn').addEventListener('click', downloadPDF);
    });
  </script>
</Layout>
