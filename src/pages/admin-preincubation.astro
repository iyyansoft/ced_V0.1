  console.log("Updating:", appId, status);   // DEBUG

  const res = await fetch(`${API_URL}/api/update-status`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      application_id: appId,
      status: status
    })
  });

  const data = await res.json();
  console.log("Update Response:", data);
}



