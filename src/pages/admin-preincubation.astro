<script>


const API_URL =
  location.hostname === "localhost"
    ? "http://localhost:8000"
    : "https://ced-backend-7uwz.onrender.com";







let allApplications = [];

function createTD(value){
  const td = document.createElement("td");
  td.textContent = value || "-";
  return td;
}

function createPPT(file){
  const td = document.createElement("td");

  if(file){
    const a = document.createElement("a");
    a.href = `http://localhost:8000/uploads/${file}`;
    a.textContent = "View";
    a.target = "_blank";
    td.appendChild(a);
  } else {
    td.textContent = "-";
  }

  return td;
}




function createStatus(status){
  const td = document.createElement("td");

  const span = document.createElement("span");
  span.className = "status-cell";

  const s = status || "Pending";
  span.textContent = s;
  applyStatusStyle(span, s);

  td.appendChild(span);
  return td;
}





function applyStatusStyle(cell, status){
  cell.className = "status-cell";   // 🔥 full reset

  if(status === "Selected") cell.classList.add("selected");
  else if(status === "Rejected") cell.classList.add("rejected");
  else cell.classList.add("pending");
}




function filterTable(status){
  const rows = document.querySelectorAll("#dataTable tbody tr");

  rows.forEach(row => {
    const cell = row.querySelector(".status-cell");
    if(!cell) return;

    const rowStatus = cell.innerText.trim();

    if(status === "all" || rowStatus === status){
      row.style.display = "";
    } else {
      row.style.display = "none";
    }
  });
}


function downloadExcel(filter){

  const tableRows = document.querySelectorAll("#dataTable tbody tr");

  if(tableRows.length === 0){
    alert("Table data not loaded yet!");
    return;
  }

  let rows = [];

  tableRows.forEach(row => {

    const statusCell = row.querySelector(".status-cell");
    if(!statusCell) return;

    const status = statusCell.innerText.trim();

    if(filter === "all" || status === filter){
     const rawDate = row.dataset.date || "";
const formattedDate = rawDate
  ? new Date(rawDate).toLocaleDateString("en-GB")
  : "";

rows.push([
  row.dataset.formattedId,
  row._fullData.name || "",
  row._fullData.email || "",
  row._fullData.mobile || "",
  row._fullData.role || "",
  row._fullData.institute || "",
  row._fullData.graduation_year || "",
  row._fullData.startup_name || "",
  row._fullData.startup_address || "",
  row._fullData.project_title || "",
  row._fullData.project_description || "",
  row._fullData.pitch || "",
  `${row._fullData.mentor_name || ""} ${row._fullData.mentor_contact || ""}`,
  row._fullData.product_type || "",
  row._fullData.sector || "",
  row._fullData.stage || "",
  row._fullData.dpiit_no || "",
  row._fullData.udyam_no || "",
  (row._fullData.services || []).join(" | "),
  status,
  formattedDate
]);

    }
  });

  if(rows.length === 0){
    alert("No matching data found!");
    return;
  }

  let csv = "ID,Name,Email,Mobile,Role,Institute,GradYear,Startup,StartupAddress,ProjectTitle,ProjectDesc,Pitch,Mentor,ProductType,Sector,Stage,DPIIT,UDYAM,Services,Status,AppliedDate\n";

  rows.forEach(r => csv += r.map(v => `"${v.replace(/"/g,'""')}"`).join(",") + "\n");

  const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
  const url = window.URL.createObjectURL(blob);

  const a = document.createElement("a");
  a.style.display = "none";
  a.href = url;
  a.download = `PreIncubation_${filter}_Data.csv`;

  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  window.URL.revokeObjectURL(url);

  document.getElementById("downloadModal").classList.remove("show");
}


document.getElementById("downloadByDateBtn").addEventListener("click", function () {

  const from = document.getElementById("fromDate").value;
  const to   = document.getElementById("toDate").value;

  if(!from || !to){
    alert("Select both From & To date");
    return;
  }

  let rows = [];

  document.querySelectorAll("#dataTable tbody tr").forEach(row => {

    const rowDate = row.dataset.date;
    if(!rowDate) return;

    if(rowDate >= from && rowDate <= to){

      const status = row.querySelector(".status-cell").innerText.trim();

      rows.push([
        row.dataset.formattedId,
        row._fullData.name || "",
        row._fullData.email || "",
        row._fullData.mobile || "",
        row._fullData.role || "",
        row._fullData.institute || "",
        row._fullData.graduation_year || "",
        row._fullData.startup_name || "",
        row._fullData.startup_address || "",
        row._fullData.project_title || "",
        row._fullData.project_description || "",
        row._fullData.pitch || "",
        `${row._fullData.mentor_name || ""} ${row._fullData.mentor_contact || ""}`,
        row._fullData.product_type || "",
        row._fullData.sector || "",
        row._fullData.stage || "",
        row._fullData.dpiit_no || "",
        row._fullData.udyam_no || "",
        (row._fullData.services || []).join(" | "),
        status,
        rowDate
      ]);
    }
  });

  if(rows.length === 0){
    alert("No data found between selected dates");
    return;
  }

  let csv = "ID,Name,Email,Mobile,Role,Institute,GradYear,Startup,StartupAddress,ProjectTitle,ProjectDesc,Pitch,Mentor,ProductType,Sector,Stage,DPIIT,UDYAM,Services,Status,AppliedDate\n";

  rows.forEach(r => {
    csv += r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(",") + "\n";
  });

  const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
  const url = URL.createObjectURL(blob);

  const a = document.createElement("a");
  a.href = url;
  a.download = `PreIncubation_${from}_to_${to}.csv`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);

  document.getElementById("downloadModal").classList.remove("show");
});





