document.querySelector(".btn-select").onclick = async (e) => {
  e.stopPropagation();

  if(!activeRow) return;

  const badge = activeRow.querySelector(".status-cell");
  const appId = activeRow.dataset.formattedId;

  badge.textContent = "Selected";
  applyStatusStyle(badge, "Selected");

  await updateStatusInDB(appId,"Selected");

  activeRow._fullData.status = "Selected";
  activeRow.dataset.status = "Selected";

  // 🔥 MAIL SEND HERE
  sendStatusMail(activeRow._fullData, "Selected");

  document.getElementById("detailModal").classList.remove("show");
};





document.querySelector(".btn-reject").onclick = async (e) => {
  e.stopPropagation();

  if(!activeRow) return;

  const badge = activeRow.querySelector(".status-cell");
  const appId = activeRow.dataset.formattedId;

  badge.textContent = "Rejected";
  applyStatusStyle(badge, "Rejected");

  await updateStatusInDB(appId,"Rejected");

  activeRow._fullData.status = "Rejected";
  activeRow.dataset.status = "Rejected";


  // 🔥 MAIL SEND HERE
  sendStatusMail(activeRow._fullData, "Rejected");

  document.getElementById("detailModal").classList.remove("show");
};








const searchBox = document.getElementById("searchBox");

searchBox.addEventListener("keyup", function () {
  const keyword = this.value.toLowerCase();
  const rows = document.querySelectorAll("#dataTable tbody tr");

  rows.forEach(row => {
    const text = row.innerText.toLowerCase();
    row.style.display = text.includes(keyword) ? "" : "none";
  });
});





document.querySelectorAll(".download-grid .btn-select[data-filter]")
.forEach(btn=>{
