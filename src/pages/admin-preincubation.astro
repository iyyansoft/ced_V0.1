function sendStatusMail(appData, status){

  emailjs.send(
    "service_l6kne7m",         // Service ID
    "template_mrf48su",        // Template ID
    {
      to_email: appData.email,
      name: appData.name,
      status: status
    },
    "yzeQ8l1jNlCdv61Fl"        // ⭐ PUBLIC KEY MUST HERE
  )
  .then(function(response){

    const toast = document.getElementById("mailToast");
    toast.innerText = "Mail sent successfully to " + appData.email + " ✅";
    toast.classList.add("show");

    setTimeout(()=>{
      toast.classList.remove("show");
    }, 3000);

    console.log("Mail sent!", response.status, response.text);

  }, function(error){
    console.error("Mail failed", error);
    alert("❌ Mail sending failed: " + error.text);
  });
}














});
