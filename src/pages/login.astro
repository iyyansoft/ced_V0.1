

<style>
body{
  background:#0c0f14;
  font-family:'Segoe UI',sans-serif;
  display:flex;
  justify-content:center;
  align-items:center;
  min-height:100vh;
  margin:0;
  overflow:hidden;
}


/* ===== Circle Loader ===== */
.circle-container{
  position:relative;
  width:520px;
  height:520px;
  display:flex;
  justify-content:center;
  align-items:center;
}

.loader{
  position:absolute;
  width:100%;
  height:100%;
  border-radius:50%;
  border:10px dashed rgba(255,255,255,0.08);   /* ⭐ dotted base */
  border-top:10px dashed #ff9f1a;              /* ⭐ yellow dotted */
  animation:spin 10s ease-in-out infinite;

}


@keyframes spin{
  0%{ transform:rotate(0deg);}
  100%{ transform:rotate(360deg);}
}

/* ===== Login Card ===== */
.login-box{
  width:240px;
  padding:25px 26px;   /* 45px → 25px, 35px → 26px */
  background:linear-gradient(145deg,#1f2633,#121722);
  border-radius:26px;
  text-align:center;
  box-shadow:0 25px 50px rgba(0,0,0,.7);
  color:#fff;
}

.login-box h2{
  color:#ff9f1a;
  letter-spacing:1px;
  margin-bottom:20px;
}

.sub{
  font-size:12px;
  color:#aaa;
  margin-bottom:16px;   /* 30px → 16px */
}

.input-field{
  position:relative;
  margin-bottom:20px;   /* 22px → 14px */
}

.input-field input{
  width:100%;
  padding:9px 6px;     /* 12px 14px → 9px 12px */
  border:none;
  outline:none;
  border-radius:30px;
  background:#0f1420;
  color:#fff;
  box-shadow:inset 3px 3px 6px #000,
             inset -3px -3px 6px #2a2f3a;
}

.input-field label{
  position:absolute;
  left:18px;
  top:50%;
  transform:translateY(-50%);
  font-size:13px;
  color:#777;
  pointer-events:none;
  transition:.3s;
}

.input-field input:focus + label,
.input-field input:valid + label{
  top:-8px;
  font-size:11px;
  color:#ff9f1a;
}

.forgot{
  display:block;
  text-align:right;
  font-size:12px;
  color:#aaa;
  margin:4px 0 18px;
  text-decoration:none;
}

.btn-login{
  width:100%;
  padding:13px;
  border-radius:30px;
  border:none;
  background:linear-gradient(135deg,#ff9f1a,#ffb347);
  font-weight:700;
  cursor:pointer;
  position:relative;
  overflow:hidden;
  color:#000;
  box-shadow:0 0 10px rgba(255,159,26,.6);
}

/* moving scan line */
.btn-login::before{
  content:"";
  position:absolute;
  top:0;
  left:-100%;
  width:100%;
  height:100%;
  background:linear-gradient(
    90deg,
    transparent,
    rgba(255,255,255,0.8),
    transparent
  );
}

/* hover animation */
.btn-login:hover::before{
  animation:scan 0.6s linear;
}

@keyframes scan{
  from{ left:-100%; }
  to{ left:100%; }
}



.or{
  font-size:12px;
  color:#888;
  margin:20px 0 12px;
}

.social-login{
  display:flex;
  justify-content:center;
  gap:14px;
}

.social-login span{
  width:36px;
  height:36px;
  border-radius:50%;
  display:flex;
  justify-content:center;
  align-items:center;
  font-size:14px;
  cursor:pointer;
  box-shadow:0 0 12px rgba(0,0,0,.6);
}

.fb{background:#1877f2;}
.x{background:#000;}
.g{background:#ea4335;}

.signup{
  margin-top:18px;
  font-size:12px;
  color:#aaa;
}

.signup span{
  color:#ff9f1a;
  cursor:pointer;
}

/* ===== Fixed grey dotted ring ===== */
.circle-bg{
  position:absolute;
  width:100%;
  height:100%;
  border-radius:50%;
  background:
    repeating-conic-gradient(
      rgba(255,255,255,0.12) 0deg 6deg,
      transparent 6deg 12deg
    );
  -webkit-mask:radial-gradient(circle at center, transparent 65%, #000 66%);
  mask:radial-gradient(circle at center, transparent 65%, #000 66%);
}

/* ===== Rotating yellow dotted arc only ===== */
.circle-rotate{
  position:absolute;
  width:100%;
  height:100%;
  border-radius:50%;
  
  background:
    conic-gradient(
     
      transparent 40deg 360deg
    );
  -webkit-mask:
    radial-gradient(circle at center, transparent 65%, #000 66%),
    repeating-conic-gradient(#000 0deg 6deg, transparent 6deg 12deg);
  mask:
    radial-gradient(circle at center, transparent 65%, #000 66%),
    repeating-conic-gradient(#000 0deg 6deg, transparent 6deg 12deg);
  animation:spin 18s ease-in-out infinite;

}

@keyframes spin{
  from{ transform:rotate(0deg); }
  to{ transform:rotate(360deg); }
}
#errorMsg{
  color:#ff4d4d;
  font-size:12px;
  margin-bottom:10px;
  display:none;
}


</style>
</head>

<body>

<div class="circle-container">
  <div class="loader"></div>

   <div class="circle-bg"></div>
   <div class="circle-rotate"></div>

<div class="login-box">
  <h2>Welcome Back</h2>
  <p class="sub">Login to continue</p>

  <div class="input-field">
    <input type="email" id="email" autocomplete="off" required>
    <label>Email Address</label>
  </div>

  <div class="input-field">
    <input type="password" id="password" autocomplete="new-password" required>
    <label>Password</label>
  </div>

  <a href="#" class="forgot">Forgot Password?</a>

  <form id="loginForm" autocomplete="off">

  <p id="errorMsg"></p>

  <button type="submit" class="btn-login">LOGIN</button>
</form>


 

 

  <p class="signup">Don't have an account? <span> Sign Up</span></p>
</div>

</div>

</div>


<script>
document.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("loginForm");
  const emailInput = document.getElementById("email");
  const passwordInput = document.getElementById("password");
  const error = document.getElementById("errorMsg");

  form.reset();

  form.addEventListener("submit", function(e){
    e.preventDefault();

    const email = emailInput.value.trim();
    const password = passwordInput.value.trim();

    error.style.display = "none";

    if(email !== "sa.cedau@gmail.com" || password !== "CED@123"){
      error.innerText = "Invalid Email or Password";
      error.style.display = "block";
      return;
    }

    // success → clear fields
    form.reset();

    // redirect
    const FRONTEND_URL =
  location.hostname === "localhost"
    ? "http://localhost:4321"
    : "https://auced.com";

  window.location.href = `${FRONTEND_URL}/admin-preincubation`;




  });

});
</script>




