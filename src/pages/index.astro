---
import Layout from "../layouts/Layout.astro";
import Header from"../components/Header.astro";
import Stats from "../components/Stats.astro";
import Services from "../components/Services.astro";
import Collaborations from "../components/Collaborations.astro";
import Guest from "../components/Guest.astro";
import Video from "../components/VideoSection.astro";

---

<Layout title="CED Anna University">
    <section>
        <Header />
        <Stats />
        <Video />
        <Services />
        <Collaborations />
         <Guest />
         
    </section>
</Layout>

<style>
.scroll-container {
  display: flex;
  overflow-x: auto;
  scroll-behavior: smooth;
  width: 100%;
  padding: 10px;
}

.scroll-arrow {
  background: none;
  border: none;
  font-size: 2rem;
  cursor: pointer;
  padding: 0 15px;
  color: #f0ad4e; /* Color for arrows */
}

.scroll-arrow:focus {
  outline: none;
}

#team-container {
  display: flex;
  flex-wrap: nowrap;
}

.card-profile {
  min-width: 240px;
}

</style>

<script>
const container = document.getElementById('team-container');



</script>